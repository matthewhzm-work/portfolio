      },
      {
        "type": "image",
        "url": "https://images.unsplash.com/photo-1563986768609-322da13575f3?w=1200&q=80",
        "caption": "Social content series"
      }
    ],
    "awards": [
      "Gold ×5 — Marketing Excellence Awards 2025",
      "Gold ×3 — Marketing Excellence Awards 2024",
      "Silver — CSR Marketing Excellence Awards 2025",
